# Common Environment Variables
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_TIMEOUT=30000
BACKEND_API_URL=http://localhost:3000
# App URLs
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_TEACHER_URL=http://localhost:3002
NEXT_PUBLIC_STUDENT_URL=http://localhost:3003

# Authentication
NEXT_PUBLIC_AUTH_ENABLED=true
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3001

# Database (if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/ebroker

# Redis (if needed)
REDIS_URL=redis://localhost:6379

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_UPLOAD_URL=/api/upload

# Feature Flags
NEXT_PUBLIC_ENABLE_GAMES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
